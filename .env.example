# Used by podman-compose. Copy to .env and fill in.
#
# The token lives only on the backend now — it is no longer exposed in the
# JavaScript bundle.

# Free token from https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Postgres credentials. Defaults are fine for local dev; rotate in production.
POSTGRES_USER=childair
POSTGRES_PASSWORD=childair
POSTGRES_DB=childair

# Ingestion frequency (minutes). 10 is the sweet spot for free-tier APIs.
SCHEDULER_INTERVAL_MIN=10

LOG_LEVEL=info
