# PostgreSQL connection — must use the asyncpg driver
DATABASE_URL=postgresql+asyncpg://childair:childair@localhost:5432/childair

# Free token from https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# How often to ingest upstream data (minutes)
SCHEDULER_INTERVAL_MIN=10

# Greater Jakarta bounding box: south,west,north,east
JAKARTA_BOUNDS=-6.55,106.55,-5.95,107.15

# Empty = no CORS (frontend served from same domain via nginx reverse proxy)
CORS_ORIGINS=

LOG_LEVEL=info
